{
  "github.copilot.enable": {
    "*": true,
    "c": true,
    "makefile": true,
    "markdown": true,
    "sql": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.mcp.autostart": "newAndOutdated",
  "C_Cpp.default.cStandard": "c11",
  "C_Cpp.default.compilerArgs": [
    "-Wall",
    "-Wextra",
    "-Wshadow",
    "-Wno-unused-result"
  ],
  "files.associations": {
    "*.h": "c",
    "Makefile": "makefile",
    "*.md": "markdown"
  },
  "editor.formatOnSave": false,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [100],
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "search.exclude": {
    "chat_program/src/**/*.o": true,
    "chat_program/src/server/chat_server": true,
    "chat_program/src/client/chat_client": true
  }
}
